# 复制本文件为 .env 并填入真实值（.env 不要提交 git）

# ---------- LLM（生成回答）----------
# 云端 API 示例（DeepSeek）：
LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
# 本地 LM Studio 则改成：
# LLM_API_KEY=lm-studio
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_MODEL=qwen2.5-7b-instruct        # 填 LM Studio 里显示的标识

# ---------- Embedding（检索用）----------
# 方案A local：本地 sentence-transformers，首次需联网下载 bge-small-zh (~100MB)
# 方案B api：走 OpenAI 兼容接口（LM Studio 需先加载一个 embedding 模型）
EMBED_BACKEND=api
EMBED_MODEL=text-embedding-bge-m3      # 填 LM Studio 里显示的标识
EMBED_BASE_URL=http://localhost:1234/v1
EMBED_API_KEY=lm-studio
# 注意：换 embedding 模型/后端后必须重跑 python ingest.py 重建向量库

# 方案A 需要的镜像加速（仅 EMBED_BACKEND=local 时有用）
# HF_ENDPOINT=https://hf-mirror.com

# ---------- 重排（可选，显著提升检索质量）----------
# 首次运行自动下载 BAAI/bge-reranker-base（约 1.1GB，走 hf-mirror）
# 设为 off 可禁用，检索自动降级为混合召回排序
# RERANK_MODEL=BAAI/bge-reranker-base
